# Server Configuration
PORT=3002
NODE_ENV=development

# PostgreSQL Database Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=54322
POSTGRES_USER=your_username
POSTGRES_PASSWORD=your_password
POSTGRES_DB=tictactoe

# PostGraphile Configuration
GRAPHQL_ENDPOINT=/graphql
GRAPHIQL_ENABLED=true
POSTGRAPHILE_USER=postgraphile_user
POSTGRAPHILE_PASSWORD=postgraphile

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# AWS Bedrock Configuration (for AI move generation)
AI_AWS_BEDROCK_ACCESS_KEY_ID=your_access_key_id
AI_AWS_BEDROCK_SECRET_ACCESS_KEY=your_secret_access_key
AI_AWS_BEDROCK_REGION=us-east-1
